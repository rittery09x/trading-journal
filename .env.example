# Copy to .env and fill in your values, then run: docker-compose up --build

# ── Supabase (self-hosted) ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://supabase.cari-digital.de
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── IBKR Flex Query ───────────────────────────────────────────────────────────
FLEX_QUERY_TOKEN=your-flex-web-service-token
FLEX_QUERY_ID_ACTIVITY=your-activity-query-id
FLEX_QUERY_ID_CONFIRMS=your-confirms-query-id

# ── Import Sicherheit ─────────────────────────────────────────────────────────
IMPORT_SECRET=your-random-secret-here

# ── App ───────────────────────────────────────────────────────────────────────
BASE_CURRENCY=EUR
NEXT_PUBLIC_APP_URL=https://trading.cari-digital.de

# ── SMTP (optional) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password
REPORT_EMAIL=your@email.com
