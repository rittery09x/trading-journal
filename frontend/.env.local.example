# ── Supabase (self-hosted) ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://supabase.cari-digital.de
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── IBKR Flex Query ───────────────────────────────────────────────────────────
# Token from: IBKR Account Management → Reports → Flex Queries → Manage
FLEX_QUERY_TOKEN=your-flex-web-service-token
FLEX_QUERY_ID_ACTIVITY=your-activity-statement-query-id
FLEX_QUERY_ID_CONFIRMS=your-trade-confirms-query-id

# ── Import Sicherheit ─────────────────────────────────────────────────────────
# Beliebiges Passwort — wird als Bearer Token für /api/import/flex geprüft
# Generieren: openssl rand -hex 32
IMPORT_SECRET=your-random-secret-here

# ── Python Backend ────────────────────────────────────────────────────────────
# Lokal ohne Docker:  http://localhost:8000
# Docker Compose:     http://backend:8000 (wird in docker-compose.yml gesetzt)
PYTHON_PARSER_URL=http://localhost:8000

# ── App ───────────────────────────────────────────────────────────────────────
BASE_CURRENCY=EUR
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── SMTP — Wochenreport (optional) ───────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password
REPORT_EMAIL=your@email.com
